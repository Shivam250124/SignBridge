# ── Local Development ─────────────────────────────────────────
DEBUG=True
PORT=8000
HOST=0.0.0.0
SECRET_KEY=dev-secret-key-change-in-production
DEPLOYMENT_MODE=local

# ── Production (set these on Render / Railway / Heroku) ───────
# DEBUG=False
# SECRET_KEY=<generate with: python3 -c "import secrets; print(secrets.token_hex(32))">
# DEPLOYMENT_MODE=cloud
# PORT is set automatically by the platform — do not override

# ── ML Settings ───────────────────────────────────────────────
GESTURE_CONFIDENCE_THRESHOLD=0.6
PREDICTION_BUFFER_SIZE=10

# ── Camera (local only — ignored in cloud mode) ───────────────
CAMERA_INDEX=0
MAX_NUM_HANDS=2
MIN_DETECTION_CONFIDENCE=0.7
MIN_TRACKING_CONFIDENCE=0.7

# ── Speech ────────────────────────────────────────────────────
SPEECH_LANGUAGE=en-IN
TTS_ENABLED=False

# ── Paths (optional overrides — defaults work for standard layout) ──
# MODELS_PATH=/app/models
# VIDEOS_PATH=/app/Speech to Sign  /videos1
